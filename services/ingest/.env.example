# services/ingest — Source fetching and delta detection (server-side only)
# Copy to .env for local overrides.

NODE_ENV=development
PORT=4001
LOG_LEVEL=info
# SIGNAL_SERVICE_VERSION=0.0.0

# Required for Firestore (source registry)
FIREBASE_PROJECT_ID=your-gcp-project-id

# Optional fetch tuning
# SIGNAL_FETCH_TIMEOUT_MS=30000
# SIGNAL_FETCH_MAX_BODY_BYTES=10485760
# SIGNAL_FETCH_USER_AGENT=Signal-ingest/dev

# Optional: protect POST /internal/run-once
# INGEST_RUN_ONCE_SECRET=change-me

# GCS + BigQuery (WS4.3). Set SIGNAL_INGEST_PERSISTENCE_ENABLED=false for local fetch-only.
# SIGNAL_INGEST_PERSISTENCE_ENABLED=true
# SIGNAL_GCS_RAW_BUCKET=myproject-signal-dev-raw
# SIGNAL_BIGQUERY_DATASET=signal_dev_analytics
# SIGNAL_BIGQUERY_SOURCE_CONTENTS_TABLE=source_contents
# SIGNAL_DEFAULT_WORKSPACE_ID=

# WS4.4 — Pub/Sub handoff after GCS + BigQuery (default off for local)
# SIGNAL_PUBLISH_SOURCE_CONTENT_EVENTS_ENABLED=false
# SIGNAL_PUBSUB_TOPIC_SOURCE_CONTENT_PERSISTED=source.delta.detected
# Wrap JSON in PipelineHandoffEnvelopeV1 (default true when unset; set false for bare events)
# SIGNAL_PIPELINE_HANDOFF_ENVELOPE_ENABLED=true

# WS10.1 — usage metering (BigQuery `usage_events`; default off)
# SIGNAL_USAGE_METERING_ENABLED=false
# SIGNAL_BIGQUERY_USAGE_EVENTS_TABLE=usage_events

# WS10.4 — backpressure (see docs/architecture/backpressure-rate-control-v1.md)
# SIGNAL_INGEST_RATE_POLICY_ENABLED=true
# SIGNAL_INGEST_MAX_SOURCES_PER_RUN=500
