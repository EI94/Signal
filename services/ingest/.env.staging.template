# services/ingest — staging. Consumed via @signal/config `loadIngestRuntimeConfig()` (+ `parseServerRuntimeEnv`).
# `GOOGLE_APPLICATION_CREDENTIALS` is used by Firebase / GCP libraries, not by @signal/config.

# --- Required ---
FIREBASE_PROJECT_ID=

# --- Optional (server runtime) ---
# NODE_ENV=staging
# PORT=4001
# LOG_LEVEL=info
# SIGNAL_SERVICE_VERSION=

# --- Optional (ingest; defaults in packages/config/src/load-ingest.ts) ---
# SIGNAL_FETCH_TIMEOUT_MS=30000
# SIGNAL_FETCH_MAX_BODY_BYTES=10485760
# SIGNAL_FETCH_USER_AGENT=
# INGEST_RUN_ONCE_SECRET=
# SIGNAL_INGEST_PERSISTENCE_ENABLED=true
# SIGNAL_GCS_RAW_BUCKET=
# SIGNAL_BIGQUERY_DATASET=
# SIGNAL_BIGQUERY_SOURCE_CONTENTS_TABLE=source_contents
# SIGNAL_DEFAULT_WORKSPACE_ID=
# SIGNAL_PUBLISH_SOURCE_CONTENT_EVENTS_ENABLED=false
# SIGNAL_PUBSUB_TOPIC_SOURCE_CONTENT_PERSISTED=source.delta.detected
# SIGNAL_PIPELINE_HANDOFF_ENVELOPE_ENABLED=true
# SIGNAL_USAGE_METERING_ENABLED=false
# SIGNAL_BIGQUERY_USAGE_EVENTS_TABLE=usage_events
# SIGNAL_INGEST_RATE_POLICY_ENABLED=true
# SIGNAL_INGEST_MAX_SOURCES_PER_RUN=500

# --- Optional (credential path; not read by @signal/config) ---
# GOOGLE_APPLICATION_CREDENTIALS=
