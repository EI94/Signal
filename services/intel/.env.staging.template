# services/intel — staging. Consumed via @signal/config `loadIntelRuntimeConfig()` (+ `parseServerRuntimeEnv`).
# `GOOGLE_APPLICATION_CREDENTIALS` is used by Firebase / GCP libraries, not by @signal/config.

# --- Required ---
FIREBASE_PROJECT_ID=

# --- Optional (server runtime) ---
# NODE_ENV=staging
# PORT=4002
# LOG_LEVEL=info
# SIGNAL_SERVICE_VERSION=

# --- Optional (intel; defaults in packages/config/src/load-intel.ts) ---
# SIGNAL_GCS_RAW_BUCKET=
# SIGNAL_BIGQUERY_DATASET=
# SIGNAL_BIGQUERY_SOURCE_CONTENTS_TABLE=source_contents
# SIGNAL_BIGQUERY_EXTRACTED_EVENTS_TABLE=extracted_events
# SIGNAL_INTEL_NORMALIZED_WRITES_ENABLED=true
# SIGNAL_INTEL_EVENT_EXTRACTION_ENABLED=false
# SIGNAL_INTEL_EXTRACTION_MAX_TEXT_CHARS=500000
# SIGNAL_INTEL_SIGNAL_PROMOTION_ENABLED=false
# SIGNAL_BIGQUERY_SIGNALS_TABLE=signals
# SIGNAL_BIGQUERY_SIGNAL_SCORE_HISTORY_TABLE=signal_score_history
# SIGNAL_BIGQUERY_ENTITY_SIGNAL_LINKS_TABLE=entity_signal_links
# SIGNAL_DEFAULT_WORKSPACE_ID=
# INTEL_INTERNAL_SECRET=
# SIGNAL_TOOL_INGEST_BASE_URL=
# SIGNAL_TOOL_INGEST_RUN_ONCE_SECRET=
# SIGNAL_PERPLEXITY_ENABLED=false
# If true, `SIGNAL_PERPLEXITY_API_KEY` must be present at runtime (local `.env` or Cloud Run env from Secret Manager `signal-<env>-perplexity-api-key`).
# SIGNAL_PERPLEXITY_API_KEY=
# SIGNAL_PERPLEXITY_BASE_URL=https://api.perplexity.ai
# SIGNAL_PERPLEXITY_MODEL=sonar
# SIGNAL_PERPLEXITY_TIMEOUT_MS=45000
# SIGNAL_ALERT_EVALUATION_ENABLED=false
# SIGNAL_BIGQUERY_ALERT_EVALUATIONS_TABLE=alert_evaluations
# SIGNAL_BRIEF_GENERATION_ENABLED=false
# SIGNAL_BRIEF_LOOKBACK_HOURS=48
# SIGNAL_BRIEF_ENRICHMENT_ENABLED=false
# SIGNAL_BRIEF_MAX_ENRICHMENT_CALLS=1
# SIGNAL_BIGQUERY_BRIEF_RUNS_TABLE=brief_runs
# SIGNAL_RESEND_ENABLED=false
# If true, SIGNAL_RESEND_API_KEY and SIGNAL_RESEND_FROM_EMAIL are required at process start.
# SIGNAL_RESEND_API_KEY=
# SIGNAL_RESEND_FROM_EMAIL=
# SIGNAL_RESEND_FROM_NAME=
# SIGNAL_RESEND_REPLY_TO=
# SIGNAL_RESEND_TIMEOUT_MS=30000
# SIGNAL_EMAIL_MAX_RECIPIENTS_PER_REQUEST=20
# SIGNAL_USAGE_METERING_ENABLED=false
# SIGNAL_BIGQUERY_USAGE_EVENTS_TABLE=usage_events

# --- Optional (credential path; not read by @signal/config) ---
# GOOGLE_APPLICATION_CREDENTIALS=
