# services/intel — SourceContent intake / normalization (server-side only)
NODE_ENV=development
PORT=4002
LOG_LEVEL=info

# Required
FIREBASE_PROJECT_ID=your-gcp-project-id

# Optional (Terraform-aligned defaults)
# SIGNAL_GCS_RAW_BUCKET=myproject-signal-dev-raw
# SIGNAL_BIGQUERY_DATASET=signal_dev_analytics
# SIGNAL_BIGQUERY_SOURCE_CONTENTS_TABLE=source_contents
# SIGNAL_BIGQUERY_EXTRACTED_EVENTS_TABLE=extracted_events

# Optional: skip writing normalized .txt to GCS (still updates BigQuery)
# SIGNAL_INTEL_NORMALIZED_WRITES_ENABLED=true

# Optional: deterministic extraction (POST /internal/extract-source-content)
# SIGNAL_INTEL_EVENT_EXTRACTION_ENABLED=false
# SIGNAL_INTEL_EXTRACTION_MAX_TEXT_CHARS=500000

# Optional: Signal promotion + scoring (POST /internal/promote-source-content-signals)
# SIGNAL_INTEL_SIGNAL_PROMOTION_ENABLED=false
# SIGNAL_BIGQUERY_SIGNALS_TABLE=signals
# SIGNAL_BIGQUERY_SIGNAL_SCORE_HISTORY_TABLE=signal_score_history
# SIGNAL_BIGQUERY_ENTITY_SIGNAL_LINKS_TABLE=entity_signal_links
# SIGNAL_DEFAULT_WORKSPACE_ID=your-workspace-id

# Optional: protect POST /internal/* (source-content-persisted, extract-source-content, promote-source-content-signals)
# INTEL_INTERNAL_SECRET=change-me

# Optional: internal tool `fetch_source` — HTTP to services/ingest POST /internal/run-once (monorepo boundary)
# SIGNAL_TOOL_INGEST_BASE_URL=http://localhost:4001
# SIGNAL_TOOL_INGEST_RUN_ONCE_SECRET=match-ingest-run-once-secret-if-set

# Optional: Perplexity Agent API (`POST {SIGNAL_PERPLEXITY_BASE_URL}/v1/agent`) for `summarize_delta` only — not on the deterministic pipeline
# SIGNAL_PERPLEXITY_ENABLED=false
# SIGNAL_PERPLEXITY_API_KEY=
# SIGNAL_PERPLEXITY_BASE_URL=https://api.perplexity.ai
# Bare model id (e.g. sonar) is sent as perplexity/<id>; or set full provider/model (e.g. perplexity/sonar-pro)
# SIGNAL_PERPLEXITY_MODEL=sonar
# SIGNAL_PERPLEXITY_TIMEOUT_MS=45000

# WS10.1 — usage metering (BigQuery `usage_events`; default off)
# SIGNAL_USAGE_METERING_ENABLED=false
# SIGNAL_BIGQUERY_USAGE_EVENTS_TABLE=usage_events

# WS10.4 — optional cost guardrails (see docs/architecture/backpressure-rate-control-v1.md)
# SIGNAL_BRIEF_MAX_ENRICHMENT_CALLS=1
# SIGNAL_EMAIL_MAX_RECIPIENTS_PER_REQUEST=20
