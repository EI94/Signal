# Browser-safe Firebase client config (NEXT_PUBLIC_* only — never put secrets here).
# Copy to .env.local for local development.
# After firebase login: firebase apps:sdkconfig WEB <AppId> --project <projectId>

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional (Console “SDK setup” — Storage, FCM sender id, Analytics). Omit if unused.
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Browser calls to apps/api (same origin in prod often via reverse proxy). No secrets.
NEXT_PUBLIC_SIGNAL_API_BASE_URL=http://localhost:4000

# Map / Leaflet — required for production builds (NODE_ENV=production). Dev may omit (OSM fallback).
# NEXT_PUBLIC_SIGNAL_MAP_TILE_URL=https://your-tile-provider.example/{z}/{x}/{y}.png
# NEXT_PUBLIC_SIGNAL_MAP_ATTRIBUTION=© Your provider
