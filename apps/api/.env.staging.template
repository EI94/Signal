# apps/api — staging. Consumed via @signal/config `loadApiRuntimeConfig()` (+ `parseServerRuntimeEnv` for NODE_ENV/PORT/LOG_LEVEL/…).
# `GOOGLE_APPLICATION_CREDENTIALS` is used by Firebase Admin / GCP libraries, not by @signal/config.
#
# Staging naming (signal-ac219): workspace `ws_maire_staging` | BigQuery `signal_staging_analytics` (EU) |
# Artifact Registry repo `signal-containers` | Cloud Run `signal-api`, `signal-ingest`, `signal-intel`.

# --- Required ---
FIREBASE_PROJECT_ID=
SIGNAL_DEFAULT_WORKSPACE_ID=

# --- Public read (optional; defaults to SIGNAL_DEFAULT_WORKSPACE_ID if unset) ---
# SIGNAL_PUBLIC_WORKSPACE_ID=ws_maire_staging

# --- Optional (server runtime; defaults in packages/config/src/server-runtime.ts / load-api.ts) ---
# NODE_ENV=staging
# PORT=4000
# LOG_LEVEL=info
# SIGNAL_SERVICE_VERSION=
# npm_package_version is injected when running via pnpm/npm.

# --- Optional (API) ---
# CORS_ORIGINS=http://localhost:3000
# SIGNAL_BIGQUERY_DATASET=
# SIGNAL_BIGQUERY_ENTITY_SIGNAL_LINKS_TABLE=entity_signal_links
# SIGNAL_BIGQUERY_USAGE_EVENTS_TABLE=usage_events
# SIGNAL_HEALTH_STALE_SIGNALS_HOURS=48
# SIGNAL_HEALTH_STALE_INGEST_HOURS=24
# SIGNAL_HEALTH_STALE_BRIEF_HOURS=72
# SIGNAL_HEALTH_USAGE_LOOKBACK_HOURS=168
# SIGNAL_INTERNAL_HEALTH_SECRET=
# SIGNAL_TOOL_INTEL_BASE_URL=
# SIGNAL_TOOL_INTEL_SECRET=

# --- Optional (local/staging credential path; not read by @signal/config) ---
# GOOGLE_APPLICATION_CREDENTIALS=
