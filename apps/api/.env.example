# apps/api — Fastify + Firebase Admin (server-side only)
# Copy to .env

NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Required: Firebase project for Admin SDK (must match web client project).
FIREBASE_PROJECT_ID=

# Required: Firestore workspace document id for default membership resolution (single-tenant MVP).
# Override per request with header X-Signal-Workspace-Id when needed.
SIGNAL_DEFAULT_WORKSPACE_ID=

# Optional: workspace id for anonymous read-only GET /v1/board/summary, /signals, /map/signals, /entities/...
# Defaults to SIGNAL_DEFAULT_WORKSPACE_ID when unset.
# SIGNAL_PUBLIC_WORKSPACE_ID=

# Comma-separated browser origins for CORS (default: http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000

# Optional: override version in /healthz and /v1/auth/me
# SIGNAL_SERVICE_VERSION=0.0.0

# WS10.2: BigQuery for entity timeline + internal health summary (usage_events freshness).
# When unset, health summary still returns Firestore freshness; usage_events timestamps are omitted.
# SIGNAL_BIGQUERY_DATASET=signal_dev_analytics
# SIGNAL_BIGQUERY_USAGE_EVENTS_TABLE=usage_events
# SIGNAL_HEALTH_STALE_SIGNALS_HOURS=48
# SIGNAL_HEALTH_STALE_INGEST_HOURS=24
# SIGNAL_HEALTH_STALE_BRIEF_HOURS=72
# SIGNAL_HEALTH_USAGE_LOOKBACK_HOURS=168
# When set, GET /internal/health/summary requires x-signal-internal-health-secret
# SIGNAL_INTERNAL_HEALTH_SECRET=

# WS11.1: tool exposure action tools (POST /v1/tools/execute → services/intel internal routes).
# When unset, read tools still work; brief/alerts/email/source.fetch return UNAVAILABLE.
# SIGNAL_TOOL_INTEL_BASE_URL=http://localhost:4002
# SIGNAL_TOOL_INTEL_SECRET=match-intel-INTEL_INTERNAL_SECRET-when-set

# Optional: Gemini for POST /v1/me/suggest-entity-sources (institutional URL suggestions in Settings).
# SIGNAL_GEMINI_SUGGEST_API_KEY=
# SIGNAL_GEMINI_SUGGEST_MODEL=gemini-2.0-flash

# Local dev: Application Default Credentials (recommended)
#   gcloud auth application-default login
# Optional: path to a service account JSON key (never commit the file)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
